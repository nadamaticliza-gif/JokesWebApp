@model JokesWebApp.Models.Joke

@{
    ViewData["Title"] = "Delete Joke";
}

<h1>Delete Joke</h1>

<div class="alert alert-warning">
    <p>Are you sure you want to delete this joke?</p>
</div>

<div class="mb-3">
    <h5>Category</h5>
    <p>@Model.Category</p>
</div>

<div class="mb-3">
    <h5>Content</h5>
    <p>@Model.Content</p>
</div>

<form asp-action="Delete" method="post" asp-route-id="@Model.Id">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
