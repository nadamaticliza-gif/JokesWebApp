@{
    ViewData["Title"] = "Search Jokes";
}

<h1><i class="bi bi-search"></i> Search Jokes</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Search" method="post">
            <div class="mb-3">
                <label class="form-label">Search by content or category:</label>
                <input name="searchString" class="form-control" placeholder="e.g. Dad, Knock-knock, Programming..." />
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Search
            </button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>