@model IEnumerable<JokesWebApp.Models.Joke>

@{
    ViewData["Title"] = "Jokes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="display-6">
        <i class="bi bi-emoji-laughing"></i> Jokes
    </h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create New
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> No jokes yet. Be the first to <a asp-action="Create" class="alert-link">add one</a>!
    </div>
}
else
{
    <div class="table-responsive shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 20%">
                        @Html.DisplayNameFor(model => model.First().Category)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.First().Content)
                    </th>
                    <th style="width: 180px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var joke in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-secondary">@joke.Category</span>
                        </td>
                        <td>@joke.Content</td>
                        <td class="text-end text-nowrap">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Details" asp-route-id="@joke.Id" class="btn btn-outline-secondary" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@joke.Id" class="btn btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@joke.Id" class="btn btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="text-muted mt-2 small">
        Total: @Model.Count() joke@(Model.Count() == 1 ? "" : "s")
    </div>
}