@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to JokesWebApp</h1>
    <p class="lead">Share and discover the funniest jokes</p>

    <div class="mt-4">
        <a class="btn btn-primary btn-lg" asp-controller="Jokes" asp-action="Index">
            Browse Jokes
        </a>
        @if (!User.Identity.IsAuthenticated)
        {
            <a class="btn btn-secondary btn-lg" asp-area="Identity" asp-page="/Account/Register">
                Sign Up
            </a>
        }
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Post Jokes</h5>
                <p class="card-text">Got a funny joke? Share it with everyone.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Comment</h5>
                    <p class="card-text">React to jokes and join the conversation.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Search</h5>
                    <p class="card-text">Find jokes by keyword or topic.</p>
                </div>
            </div>
        </div>
    </div>
