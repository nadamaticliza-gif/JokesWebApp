@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "My Profile";
}

<h2 class="mb-4">My Profile</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Username:</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">Email:</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Email Confirmed:</dt>
            <dd class="col-sm-9">@Model.EmailConfirmed</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary">
        Manage Account
    </a>
    <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-secondary">
        Change Password
    </a>
</div>